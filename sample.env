# Copy this file to `.env` in the project root for local development.
#
# The app loads ROOT/.env from config/bootstrap.php.
# Keep real secrets out of version control.

DEBUG=true

# Set this explicitly in production. In local development, use your local app URL.
APP_FULL_BASE_URL=http://localhost:8080

# Generate a unique random value for each project/environment.
SECURITY_SALT=replace-with-a-random-security-salt

# Primary application database.
# Example MySQL DSN:
# DATABASE_URL=mysql://app_user:app_password@localhost:3306/app_name?encoding=utf8mb4&timezone=UTC&cacheMetadata=true&quoteIdentifiers=false&persistent=false
DATABASE_URL=

# Optional test database override.
# DATABASE_TEST_URL=sqlite://127.0.0.1/tmp/tests.sqlite

# Optional IdentityBridge / Appwrite configuration.
# Leave blank if this project will not use Appwrite-backed bearer-token auth.
APPWRITE_PROJECT_ID=
APPWRITE_ENDPOINT=

# Optional helper values for tests or local scripts that hit /api/identity/me.
DEMO_EMAIL=
DEMO_PASSWORD=
